model Floor {
    id        Int      @id @default(autoincrement())
    name      String
    slug      String   @unique
    order     Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    documentation      MonthlyDocumentation[]
    officialReports    OfficialReport[]
    floorInspections   FloorInspection[]
    floorDeviceConfigs FloorDeviceConfig[]
}
