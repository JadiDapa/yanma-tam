model User {
    id                          Int               @id @default(autoincrement())
    name                        String
    email                       String            @unique
    username                    String            @unique
    role                        UserRole          @default(GUEST)
    nip                         String?
    attendanceListsAsEOS        AttendanceList[]  @relation("EOS")
    attendanceListsAsSupervisor AttendanceList[]  @relation("Supervisor")
    createdAt                   DateTime          @default(now())
    updatedAt                   DateTime          @updatedAt
    attendanceLists             AttendanceList[]
    floorInspections            FloorInspection[]
}

enum UserRole {
    ADMIN
    EOS
    SUPERVISOR
    TECHNICIAN
    GUEST
}
