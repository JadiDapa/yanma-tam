model Device {
    id               BigInt   @id @default(autoincrement())
    slug             String   @unique
    name             String
    order            Int
    template         String?
    handoverTemplate String?
    isActive         Boolean  @default(true)
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    monthlyDocumentations MonthlyDocumentation[]
    floorDeviceConfigs    FloorDeviceConfig[]
    deviceHandover        DeviceHandover[]
}
